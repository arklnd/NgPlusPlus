{
    "name": "ngplusplus",
    "version": "1.0.0",
    "description": "Angular major version upgrade CLI agent powered by LangGraph multi-agent workflow",
    "main": "dist/index.js",
    "type": "module",
    "bin": {
        "ngpp": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:watch": "tsc -p tsconfig.build.json --watch",
        "clean:build": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
        "clean:db": "node -e \"const fs=require('fs'),path=require('path');function d(dir){const f=fs.readdirSync(dir);for(const e of f){const p=path.join(dir,e);fs.statSync(p).isDirectory()?d(p):e.endsWith('.db')&&fs.rmSync(p,{force:true})}}d('.')\"",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "rebuild": "npm run clean:build && tsc -p tsconfig.build.json",
        "show:cache": "tsx .github/scripts/print-cache.ts",
        "test": "npx mocha"
    },
    "author": "Arijit Kundu",
    "license": "ISC",
    "devDependencies": {
        "@types/adm-zip": "0.5.7",
        "@types/better-sqlite3": "7.6.13",
        "@types/chai": "5.2.2",
        "@types/handlebars": "4.0.40",
        "@types/mocha": "10.0.10",
        "@types/node": "^24.2.1",
        "@types/npmcli__arborist": "6.3.1",
        "chai": "5.2.1",
        "mocha": "11.7.1",
        "nyc": "17.1.0",
        "source-map-support": "0.5.21",
        "tsx": "4.20.5",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@langchain/core": "^0.3.0",
        "@langchain/langgraph": "^0.2.0",
        "@langchain/openai": "^0.5.0",
        "@npmcli/arborist": "9.1.9",
        "@types/semver": "7.7.0",
        "adm-zip": "0.5.16",
        "better-sqlite3": "12.4.1",
        "commander": "^13.0.0",
        "dotenv": "17.2.1",
        "fast-deep-equal": "3.1.3",
        "handlebars": "4.7.8",
        "semver": "7.7.2",
        "simple-git": "3.28.0",
        "zod": "^3.23.8"
    }
}
