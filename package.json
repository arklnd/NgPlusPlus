{
    "name": "ngplusplus",
    "displayName": "NgPlusPlus",
    "description": "AI-powered Angular major version upgrade extension using LangGraph multi-agent workflow",
    "version": "1.0.0",
    "publisher": "arijit-kundu",
    "license": "ISC",
    "author": "Arijit Kundu",
    "icon": "media/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/ArijitKundu-repo/NgPlusPlus"
    },
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "angular",
        "upgrade",
        "dependency",
        "migration",
        "ai"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "ngplusplus.upgrade",
                "title": "NgPlusPlus: Upgrade Angular Dependencies"
            },
            {
                "command": "ngplusplus.selectModel",
                "title": "NgPlusPlus: Select LLM Model"
            },
            {
                "command": "ngplusplus.showConfig",
                "title": "NgPlusPlus: Show Configuration"
            }
        ],
        "configuration": {
            "title": "NgPlusPlus",
            "properties": {
                "ngplusplus.llmProvider": {
                    "type": "string",
                    "default": "vscode",
                    "enum": [
                        "vscode",
                        "openai"
                    ],
                    "enumDescriptions": [
                        "Use VS Code built-in Language Model API (GitHub Copilot, etc.)",
                        "Use OpenAI-compatible API endpoint (OpenAI, Ollama, Azure, LM Studio, etc.)"
                    ],
                    "description": "Which LLM provider to use for AI-powered dependency resolution"
                },
                "ngplusplus.vscodeModel": {
                    "type": "string",
                    "default": "",
                    "description": "VS Code Language Model identifier to use (leave empty to prompt on first use). Use 'NgPlusPlus: Select LLM Model' command to pick from available models."
                },
                "ngplusplus.openai.baseUrl": {
                    "type": "string",
                    "default": "https://api.openai.com/v1",
                    "description": "Base URL for the OpenAI-compatible API endpoint"
                },
                "ngplusplus.openai.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "API key for the OpenAI-compatible endpoint (stored in VS Code settings; consider using a secrets manager for production use)"
                },
                "ngplusplus.openai.model": {
                    "type": "string",
                    "default": "gpt-4",
                    "description": "Model name for the OpenAI-compatible endpoint"
                },
                "ngplusplus.openai.temperature": {
                    "type": "number",
                    "default": 0.3,
                    "minimum": 0,
                    "maximum": 2,
                    "description": "Temperature for LLM responses (lower = more deterministic)"
                },
                "ngplusplus.openai.maxTokens": {
                    "type": "number",
                    "default": 2000,
                    "minimum": 100,
                    "maximum": 128000,
                    "description": "Maximum tokens for LLM responses"
                },
                "ngplusplus.openai.timeout": {
                    "type": "number",
                    "default": 60000,
                    "minimum": 5000,
                    "maximum": 300000,
                    "description": "Timeout in milliseconds for LLM API calls"
                },
                "ngplusplus.maxAttempts": {
                    "type": "number",
                    "default": 200,
                    "minimum": 1,
                    "maximum": 1000,
                    "description": "Maximum number of dependency resolution attempts"
                },
                "ngplusplus.logLevel": {
                    "type": "string",
                    "default": "info",
                    "enum": [
                        "error",
                        "warn",
                        "info",
                        "debug",
                        "trace"
                    ],
                    "description": "Log verbosity level for the output channel"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "lint": "npx tsc --noEmit",
        "package": "npx @vscode/vsce package",
        "clean:build": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
        "clean:db": "node -e \"const fs=require('fs'),path=require('path');function d(dir){const f=fs.readdirSync(dir);for(const e of f){const p=path.join(dir,e);fs.statSync(p).isDirectory()?d(p):e.endsWith('.db')&&fs.rmSync(p,{force:true})}}d('.')\"",
        "test": "npx mocha"
    },
    "devDependencies": {
        "@types/adm-zip": "0.5.7",
        "@types/better-sqlite3": "7.6.13",
        "@types/chai": "5.2.2",
        "@types/handlebars": "4.0.40",
        "@types/mocha": "10.0.10",
        "@types/node": "^22.0.0",
        "@types/npmcli__arborist": "6.3.1",
        "@types/vscode": "1.120.0",
        "chai": "5.2.1",
        "esbuild": "0.25.12",
        "mocha": "11.7.1",
        "nyc": "17.1.0",
        "source-map-support": "0.5.21",
        "tsx": "4.20.5",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@langchain/core": "^0.3.0",
        "@langchain/langgraph": "^0.2.0",
        "@langchain/openai": "^0.5.0",
        "@npmcli/arborist": "9.1.9",
        "@types/semver": "7.7.0",
        "adm-zip": "0.5.16",
        "better-sqlite3": "12.4.1",
        "fast-deep-equal": "3.1.3",
        "handlebars": "4.7.8",
        "semver": "7.7.2",
        "simple-git": "3.28.0",
        "zod": "^3.23.8"
    }
}
