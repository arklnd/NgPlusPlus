{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"],
            "@G/*": ["src/graph/*"],
            "@U/*": ["src/utils/*"],
            "@S/*": ["src/services/*"],
            "@E/*": ["src/exceptions/*"],
            "@I/*": ["src/interfaces/*"]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "**/*.test.ts",
        "**/*.spec.ts",
        "test/**/*"
    ]
}
